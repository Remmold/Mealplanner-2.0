# Create a .env in the same directory matching these key-value pairs with your own values.
# Anything marked REQUIRED is needed for the new auth/household endpoints to work.

# ============================================================================
# Supabase — REQUIRED for /me, /households/*, /accounts/*
# ============================================================================
# Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API -> anon public key (safe to expose to the frontend)
SUPABASE_ANON_KEY=eyJhbGc...
# Project Settings -> API -> service_role key (SECRET — backend only, never commit)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# Project Settings -> API -> JWT Settings -> JWT Secret (HS256)
SUPABASE_JWT_SECRET=your-32-char-jwt-secret-from-supabase

# Direct Postgres connection. Project Settings -> Database -> Connection string.
# Recommended: the TRANSACTION POOLER URI (port 6543) — it's serverless-ready
# and what asyncpg's statement_cache_size=0 is tuned for.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ============================================================================
# Hearth runtime — REQUIRED
# ============================================================================
# Used to build the /join/<token> URLs returned by the invite endpoint.
# In production this is your public domain. In dev it's the frontend dev server.
HEARTH_PUBLIC_URL=http://localhost:5173

# ============================================================================
# OpenAI (existing) — REQUIRED for AI recipe gen, chat, weekly planner
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
# Default LLM for the capped-AI beta (cheaper than gpt-4o).
OPENAI_RECIPE_MODEL=gpt-4o-mini

# ============================================================================
# Capped-AI beta config (optional; defaults shown)
# ============================================================================
# Per-household free credit grant inserted on first action of each month.
MONTHLY_CREDIT_GRANT=30
# Global kill-switch: when month-to-date OpenAI spend crosses this, AI
# endpoints return 503 until next calendar month.
MONTHLY_BUDGET_USD=50

# ============================================================================
# Existing — Open Food Facts ingestion (dev-only; OFF is cut from prod)
# ============================================================================
OFF_DUMP_PATH=off_dump.jsonl.gz
OFF_CATEGORIES=en:meals,en:breakfasts,en:snacks,en:dairy-products,en:fruits-and-vegetables,en:meats,en:fish-and-seafood,en:cereals-and-their-products,en:breads
OFF_MAX_RECORDS=0
DUCKDB_PATH=food_data.duckdb
