# Create a .env in the same directory matching these key-value pairs with your own values

# --- Open Food Facts dump ---
# Path to the local JSONL dump file. Downloaded automatically if missing.
# Source: https://static.openfoodfacts.org/data/openfoodfacts-products.jsonl.gz
OFF_DUMP_PATH=off_dump.jsonl.gz

# Categories to ingest (comma-separated OFF category tags).
# Leave blank to use the built-in defaults.
OFF_CATEGORIES=en:meals,en:breakfasts,en:snacks,en:dairy-products,en:fruits-and-vegetables,en:meats,en:fish-and-seafood,en:cereals-and-their-products,en:breads

# Stop after N matched records. 0 = no limit. Set to e.g. 5000 for a quick test.
OFF_MAX_RECORDS=0

# --- Local DuckDB (default destination) ---
DUCKDB_PATH=food_data.duckdb

# --- Supabase / PostgreSQL (optional production destination) ---
# DESTINATION=postgres
# POSTGRES_CONNECTION_STRING=postgresql://user:password@host:port/dbname
